## Database Configuration (Compatible with MySQL and TiDB)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=chess_3d_db

## TiDB Cloud / Serverless Configuration
## Set MYSQL_SSL to true when connecting to TiDB Serverless in the cloud
# MYSQL_SSL=false
# MYSQL_SSL_REJECT_UNAUTHORIZED=true
